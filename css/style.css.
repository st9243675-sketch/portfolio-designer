/* 1. Базове скидання відступів (щоб сайт прилягав до країв екрана) */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    background-color: #121212; /* Темний фон для всього сайту */
    color: #ffffff; /* Загальний колір тексту - білий */
    font-family: sans-serif;
}

/* --- СЕКЦІЯ HERO --- */
.hero {
    padding: 80px 0; /* Відступи зверху і знизу, щоб дихало */
}

.hero__content {
    max-width: 500px; /* Обмежуємо ширину тексту, щоб він не був на весь екран */
}

.hero__subtitle {
    font-size: 20px;
    margin-bottom: 10px;
}

.hero__title {
    font-size: 64px;
    font-weight: bold;
    margin-bottom: 10px;
}

.hero__profession {
    font-size: 32px;
    color: #a855f7; /* Фіолетовий акцентний колір */
    margin-bottom: 20px;
}

.hero__description {
    font-size: 16px;
    color: #aaaaaa; /* Робимо опис трохи тьмянішим */
    margin-bottom: 40px;
    line-height: 1.5;
}

/* --- СТИЛІ КНОПКИ --- */
.btn {
    display: inline-block !important;
    background-color: #a855f7; /* Фіолетовий фон */
    color: #ffffff;
    text-decoration: none;
    padding: 15px 35px !important;
    border-radius: 5px; /* Закруглені кути */
    font-weight: bold;
    transition: background-color 0.3s ease; /* Плавна зміна кольору */
    width: max-content !important; /* Кнопка не буде розтягуватися */
    text-align: center !important;
}

.btn:hover {
    background-color: #a684c5; /* Темніший фіолетовий при наведенні */
}

/* --- СТИЛІ ДЛЯ РЕАЛЬНОГО ФОТО --- */
.hero__photo {
    width: 380px; /* Задаємо фіксовану ширину */
    height: 380px; /* Задаємо таку ж фіксовану висоту */
    border-radius: 50%; /* Робить квадрат кругом */
    object-fit: cover; /* Фото автоматично обріжеться, не розтягуючись */
    border: 8px solid #a855f7; 
    box-shadow: 0 10px 20px rgba(0,0,0,0.5); 
}

/* 2. Стилі для шапки сайту */
.header {
    background-color: #2c2929; /* Темний фон */
    padding: 20px 0; 
}

/* 3. Контейнер, щоб контент не розтягувався */
.container {
    max-width: 1200px;
    margin: 0 auto; 
    display: flex; 
    justify-content: space-between; 
    align-items: center; 
    padding: 0 20px;
}

/* 4. Стилі для списку меню */
.nav__list {
    display: flex; 
    list-style: none; 
    gap: 30px; 
}

/* 5. Стилі для самих посилань (тексту) */
.nav__link, .logo {
    text-decoration: none; 
    color: #ffffff; 
    font-family: sans-serif; 
}

.logo {
    font-size: 24px;
    font-weight: bold;
}

/* ========================================= */
/* ВИПРАВЛЕННЯ БАГІВ ДЛЯ КОМП'ЮТЕРА (ПК)     */
/* ========================================= */

/* Примусово ховаємо гігантську іконку меню в шапці на великих екранах */
@media (min-width: 769px) {
    .header svg,
    .header img:not(.logo),
    .burger, 
    .burger-menu, 
    .menu-icon,
    #menu-btn {
        display: none !important;
    }
}
