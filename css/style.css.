/* 1. Базове скидання відступів (щоб сайт прилягав до країв екрана) */
* { /* Універсальний селектор: вибирає абсолютно всі елементи на сайті */
    margin: 0; /* Прибирає всі зовнішні відступи за замовчуванням */
    padding: 0; /* Прибирає всі внутрішні відступи за замовчуванням */
    box-sizing: border-box; /* Рамки та відступи включаються в загальну ширину елемента */
} /* Закриваємо правило для всіх елементів */

body { /* Селектор тегу body: задає стилі для всієї сторінки */
    background-color: #121212; /* Встановлює темно-сірий (майже чорний) колір фону сайту */
    color: #ffffff; /* Встановлює білий колір для всього тексту на сайті */
    font-family: sans-serif; /* Задає стандартний шрифт без засічок (наприклад, Arial) */
} /* Закриваємо стилі для body */

/* --- СЕКЦІЯ HERO --- */
.hero { /* Клас для головного блоку (першого екрану) сайту */
    padding: 80px 0; /* Додає внутрішні відступи: 80px зверху/знизу і 0px з боків */
} /* Закриваємо стилі блоку hero */

.hero__content { /* Клас для контейнера з текстом у секції hero */
    max-width: 500px; /* Обмежує максимальну ширину текстового блоку до 500 пікселів */
} /* Закриваємо стилі hero__content */

.hero__subtitle { /* Клас для підзаголовка у секції hero */
    font-size: 20px; /* Встановлює розмір шрифту підзаголовка 20 пікселів */
    margin-bottom: 10px; /* Додає відступ знизу 10 пікселів, щоб відсунути наступний текст */
} /* Закриваємо стилі hero__subtitle */

.hero__title { /* Клас для головного заголовка сторінки */
    font-size: 64px; /* Встановлює дуже великий розмір шрифту - 64 пікселі */
    font-weight: bold; /* Робить шрифт головного заголовка жирним */
    margin-bottom: 10px; /* Додає відступ знизу 10 пікселів */
} /* Закриваємо стилі hero__title */

.hero__profession { /* Клас для тексту з назвою професії */
    font-size: 32px; /* Встановлює розмір шрифту 32 пікселі */
    color: #a855f7; /* Фарбує текст професії у яскравий фіолетовий колір */
    margin-bottom: 20px; /* Додає відступ знизу 20 пікселів */
} /* Закриваємо стилі hero__profession */

.hero__description { /* Клас для тексту-опису під заголовками */
    font-size: 16px; /* Встановлює стандартний розмір шрифту 16 пікселів */
    color: #aaaaaa; /* Фарбує текст опису в світло-сірий колір */
    margin-bottom: 40px; /* Робить великий відступ знизу (40px) перед кнопкою */
    line-height: 1.5; /* Встановлює міжрядковий інтервал в 1.5 рази більший за сам шрифт */
} /* Закриваємо стилі hero__description */

/* --- СТИЛІ КНОПКИ --- */
.btn { /* Клас для стилізації кнопок на сайті */
    display: inline-block !important; /* Робить елемент блочно-рядковим (щоб працювали розміри), !important - пріоритет */
    background-color: #a855f7; /* Задає кнопці фіолетовий колір фону */
    color: #ffffff; /* Робить текст всередині кнопки білим */
    text-decoration: none; /* Прибирає стандартне нижнє підкреслення тексту */
    padding: 15px 35px !important; /* Задає відступи всередині кнопки: 15px по вертикалі, 35px по горизонталі */
    border-radius: 5px; /* Закруглює кути кнопки на 5 пікселів */
    font-weight: bold; /* Робить текст на кнопці жирним */
    transition: background-color 0.3s ease; /* Додає плавний перехід зміни кольору фону тривалістю 0.3 секунди */
    width: max-content !important; /* Ширина кнопки підлаштовується рівно під довжину тексту всередині */
    text-align: center !important; /* Вирівнює текст рівно по центру кнопки */
} /* Закриваємо базові стилі кнопки */

.btn:hover { /* Псевдоклас: стилі, які спрацьовують при наведенні курсору миші на кнопку */
    background-color: #a684c5; /* Змінює колір фону кнопки на світліший фіолетовий при наведенні */
} /* Закриваємо стилі наведення на кнопку */

/* --- НОВІ СТИЛІ ДЛЯ РЕАЛЬНОГО ФОТО --- */
.hero__photo { /* Клас для стилізації фотографії користувача */
    width: 380px; /* Фіксує ширину фотографії рівно в 380 пікселів */
    height: 380px; /* Фіксує висоту фотографії рівно в 380 пікселів (разом із шириною утворює квадрат) */
    border-radius: 50%; /* Закруглює квадрат на 50%, перетворюючи його на ідеальне коло */
    object-fit: cover; /* Обрізає фото по центру, щоб пропорції не спотворювались (не розтягувались) */
    border: 8px solid #a855f7; /* Додає навколо фото суцільну рамку товщиною 8px фіолетового кольору */
    box-shadow: 0 10px 20px rgba(0,0,0,0.5); /* Додає тінь: 0px по X, 10px по Y, розмиття 20px, колір - чорний напівпрозорий */
} /* Закриваємо стилі фотографії */

/* 2. Стилі для шапки сайту */
.header { /* Клас для верхньої панелі (шапки) сайту */
    background-color: #2c2929; /* Встановлює темно-сірий (майже графітовий) колір фону шапки */
    padding: 20px 0; /* Додає внутрішні відступи всередині шапки: 20px зверху/знизу, 0px з боків */
} /* Закриваємо стилі шапки */

/* 3. Контейнер, щоб контент не розтягувався на весь екран */
.container { /* Клас-обгортка для центрування контенту */
    max-width: 1200px; /* Обмежує максимальну ширину контенту до 1200 пікселів */
    margin: 0 auto; /* Автоматично вираховує відступи з боків, щоб відцентрувати контейнер по горизонталі */
    display: flex; /* Вмикає Flexbox, щоб елементи всередині стали в один горизонтальний ряд */
    justify-content: space-between; /* Розсуває елементи максимально по краях (логотип наліво, меню направо) */
    align-items: center; /* Вирівнює всі елементи всередині контейнера по центру вертикальної осі */
    padding: 0 20px; /* Додає безпечні відступи по 20px з боків, щоб контент не прилипав до країв на малих екранах */
} /* Закриваємо стилі контейнера */

/* 4. Стилі для списку меню */
.nav__list { /* Клас для тегу <ul>, який містить пункти меню навігації */
    display: flex; /* Вмикає Flexbox, щоб пункти меню стали в один горизонтальний рядок */
    list-style: none; /* Прибирає стандартні кружечки (маркери) зі списку */
    gap: 30px; /* Встановлює фіксовану відстань у 30 пікселів між кожним сусіднім пунктом меню */
} /* Закриваємо стилі списку меню */

/* 5. Стилі для самих посилань (тексту) */
.nav__link, .logo { /* Застосовує наступні стилі одночасно і до посилань у меню, і до логотипу */
    text-decoration: none; /* Прибирає стандартне синє підкреслення з посилань */
    color: #ffffff; /* Робить текст посилань та логотипу білого кольору */
    font-family: sans-serif; /* Встановлює для них шрифт без засічок */
} /* Закриваємо спільні стилі для посилань та лого */

.logo { /* Специфічні стилі тільки для логотипу (додаються до попередніх) */
    font-size: 24px; /* Збільшує розмір шрифту логотипу до 24 пікселів */
    font-weight: bold; /* Робить текст логотипу жирним */
} /* Закриваємо додаткові стилі логотипу */

/* ========================================= */
/* ВИПРАВЛЕННЯ ДЛЯ КОМП'ЮТЕРА (ПК)           */
/* ========================================= */

/* Примусово ховаємо мобільне меню та всі зайві іконки в шапці на великих екранах */
@media (min-width: 769px) { /* Медіа-запит: стилі всередині спрацюють лише на екранах шириною від 769px і більше */
    .header svg, /* Вибирає всі SVG-іконки всередині шапки */
    .header img:not(.logo), /* Вибирає всі картинки в шапці, ОКРІМ тієї, що має клас .logo */
    .burger,  /* Вибирає елемент з класом .burger (іконка мобільного меню) */
    .burger-menu,  /* Вибирає елемент з класом .burger-menu (саме мобільне меню) */
    .menu-icon, /* Вибирає елемент з класом .menu-icon */
    #menu-btn { /* Вибирає елемент з ідентифікатором menu-btn (кнопка відкриття меню) */
        display: none !important; /* Повністю приховує всі перелічені вище елементи на ПК, !important перебиває все інше */
    } /* Закриваємо правило приховування */
} /* Закриваємо медіа-запит */
